# ──────────────────────────────────────────────────
# AI Wellness Buddy — Backend environment variables
# Copy this file to .env and fill in real values.
# NEVER commit the real .env to source control.
# ──────────────────────────────────────────────────

# Application
APP_NAME="AI Wellness Buddy"
APP_VERSION="2.0.0"
DEBUG=false

# CRITICAL for local development:
# ENV must be "development" so the auth cookie is NOT marked Secure.
# A Secure cookie is only sent over HTTPS; over plain HTTP the browser
# silently drops it, which causes 401 errors on every request after login.
ENV=development

# API
API_PREFIX="/api/v1"
# Comma-separated list of allowed CORS origins.
# Use ONLY "localhost" or ONLY "127.0.0.1" — never mix the two.
# Mixing causes SameSite=Lax cookies to be treated as cross-site and dropped.
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001","https://your-frontend.vercel.app"]
# Single frontend URL to allow (merged with ALLOWED_ORIGINS).
# Preferred for Vercel deployments — just set this to your Vercel URL.
# Example: FRONTEND_URL=https://ai-wellness-buddy.vercel.app
FRONTEND_URL=

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
# SQLite (development):
DATABASE_URL=sqlite+aiosqlite:///./wellness.db
# PostgreSQL (Railway managed — Railway auto-injects DATABASE_URL):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/wellness_db

# HuggingFace — obtain a token at https://huggingface.co/settings/tokens
# Required for gated models; optional for public models (may hit rate limits).
HF_TOKEN=

# Safety
CRISIS_CONFIDENCE_THRESHOLD=0.6
HIGH_RISK_ESCALATION_MESSAGE="I'm concerned about your wellbeing. Please reach out: 988 Suicide & Crisis Lifeline (call/text 988) or Crisis Text Line (text HOME to 741741)."

# Logging
# Use DEBUG to see detailed cookie/token diagnostics when troubleshooting 401s.
LOG_LEVEL=INFO
# LOG_LEVEL=DEBUG

# ──────────────────────────────────────────────────
# Railway deployment — required environment variables
# Set these in the Railway dashboard under Variables.
# ──────────────────────────────────────────────────
#
#   SECRET_KEY          — JWT signing secret (mandatory)
#                         python -c "import secrets; print(secrets.token_hex(32))"
#   DATABASE_URL        — injected automatically by Railway PostgreSQL plugin
#   HF_TOKEN            — HuggingFace access token for model downloads
#   FRONTEND_URL        — your Vercel frontend URL for CORS
#   ALLOWED_ORIGINS     — JSON array, e.g. ["https://your-app.vercel.app"]
#   ENV                 — set to "production" on Railway
#   LOG_LEVEL           — INFO (default)
