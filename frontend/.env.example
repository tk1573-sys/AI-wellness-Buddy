# ───────────────────────────────────────────────────────
# AI Wellness Buddy — Frontend environment variables
# Copy to .env.local and fill in real values.
# NEVER commit .env.local to source control.
# ───────────────────────────────────────────────────────

# Backend API base URL.
# • Local development: http://localhost:8000
#
#   CRITICAL — hostname consistency:
#   Use "localhost" everywhere (both here and in the browser address bar).
#   Do NOT mix "localhost" and "127.0.0.1".
#   Mixing them causes the browser to treat the auth cookie as cross-site
#   (SameSite=Lax), which silently drops it on subsequent requests and
#   results in 401 Unauthorized errors after a successful login.
#
#   Also ensure the backend ENV variable is set to "development" so the
#   cookie's Secure flag is disabled (required for plain HTTP).
#
# • Vercel / production: set this to your deployed backend URL, e.g.
#     https://api.your-domain.com
#   Then set the matching FRONTEND_URL on the backend so CORS is allowed.
NEXT_PUBLIC_API_URL=http://localhost:8000
