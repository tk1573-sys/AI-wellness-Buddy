# ───────────────────────────────────────────────────────
# AI Wellness Buddy — Frontend environment variables
# Copy to .env.local and fill in real values.
# NEVER commit .env.local to source control.
# ───────────────────────────────────────────────────────

# Backend API base URL.
# • Local development: http://localhost:8000
#   IMPORTANT: use "localhost" (not "127.0.0.1") so that the auth cookie
#   set by the backend is treated as same-site by the browser, which is
#   required for SameSite=Lax cookies to be sent on subsequent API calls.
# • Vercel / production: set this to your deployed backend URL, e.g.
#     https://api.your-domain.com
#   Then set the matching FRONTEND_URL on the backend so CORS is allowed.
NEXT_PUBLIC_API_URL=http://localhost:8000
