# ───────────────────────────────────────────────────────
# AI Wellness Buddy — Frontend environment variables
# Copy to .env.local and fill in real values.
# NEVER commit .env.local to source control.
# ───────────────────────────────────────────────────────

# Backend URL used by the Next.js proxy (next.config.js rewrites).
# All /api/* requests from the browser are forwarded server-side to this URL,
# which eliminates CORS issues and ensures HttpOnly auth cookies are set and
# forwarded correctly.
#
# Local development (default — no .env.local required):
#   BACKEND_URL=http://localhost:8000
#
# Docker / staging / production: set this to the internal or public backend URL.
#   BACKEND_URL=http://backend:8000       # Docker compose service name
#   BACKEND_URL=https://api.your-domain.com
BACKEND_URL=http://localhost:8000
